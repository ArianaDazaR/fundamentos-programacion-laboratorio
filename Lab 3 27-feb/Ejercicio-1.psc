Algoritmo SumarDosNumeros
	
	Definir numero1, numero2, resultado Como Real
	
	Escribir "Suma de dos numeros"
	Escribir ""
	
	Escribir "Ingrese el primer numero: "
	Leer numero1
	
	Escribir "Ingrese el segundo numerio: "
	Leer numero2
	
	resultado <- numero1 + numero2
	
	Escribir ""
	Escribir "El resultado de sumar ", numero1, " + ", numero2, " es ", resultado
	
FinAlgoritmo
