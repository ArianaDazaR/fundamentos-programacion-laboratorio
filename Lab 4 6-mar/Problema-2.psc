Algoritmo CompraEnUnaTienda
	Definir nombre como Caracter
	Definir cantidad, total Como Real
	Escribir "Registro de Ventas"
	Escribir ""
	Escribir "Nombre del cliente: "
	Leer nombre
	Escribir "Cantidad de prodcuto: "
	Leer cantidad
	total<-cantidad*8
	Escribir ""
