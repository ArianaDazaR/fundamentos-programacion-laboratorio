Algoritmo AreaDeUnTriangulo
	Definir base, altura, area Como Real
	Escribir "Calculadora de Area de Triangulos"
	Escribir ""
	Escribir "Dimensiones"
	Escribir "Ingrese base: "
	Leer base
	Escribir "Ingrese altura: "
	Leer altura
	area<-(base*altura)/2
	Escribir ""
	Escribir "El area total es: ", area
FinAlgoritmo
